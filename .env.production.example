# ============================================
# 生产环境配置示例
# 复制为 .env 并修改实际值
# ============================================

# 服务器信息
SERVER_IP=your-server-ip
SERVER_USER=root
DEPLOY_DIR=/opt/gacha-system

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=gacha_system_prod
DB_USERNAME=root
DB_PASSWORD=Xc037417!

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=Xc037417!

# RabbitMQ 配置
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=admin
RABBITMQ_PASSWORD=Xc037417!

# Elasticsearch 配置（版本：7.17.29）
ES_HOST=localhost
ES_PORT=9200
ES_URIS=http://localhost:9200

# JWT 配置（生产环境务必修改）
JWT_SECRET=YourVeryLongAndSecureSecretKeyForProductionEnvironment2026ChangeThis

# 阿里云短信配置
SMS_ACCESS_KEY_ID=your-access-key-id
SMS_ACCESS_KEY_SECRET=your-access-key-secret

# 微信支付配置
WECHAT_PAY_APP_ID=your-app-id
WECHAT_PAY_MCH_ID=your-mch-id
WECHAT_PAY_API_V3_KEY=your-api-v3-key
WECHAT_PAY_SERIAL_NO=your-serial-no
WECHAT_PAY_NOTIFY_URL=https://your-domain.com/api/payment/wechat/notify
