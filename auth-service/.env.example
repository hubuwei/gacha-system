# ============================================
# Auth Service 环境配置
# ============================================

# 应用配置
APP_NAME=auth-service
APP_PORT=8084

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=gacha_system_dev
DB_USERNAME=root
DB_PASSWORD=123456
DB_USE_SSL=false
DB_TIMEZONE=UTC
DB_ENCODING=utf-8

# JPA 配置
JPA_DDL_AUTO=update
JPA_SHOW_SQL=true
JPA_DIALECT=org.hibernate.dialect.MySQLDialect

# 日志配置
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_AUTH=DEBUG
LOG_LEVEL_COMMON=DEBUG
LOG_LEVEL_SPRING_WEB=DEBUG
LOG_LEVEL_HIBERNATE_SQL=DEBUG

# JWT 配置
JWT_SECRET=ThisIsAVeryLongAndSecureSecretKeyForJWTTokenGenerationWithHS512AlgorithmInGachaSystem2026
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# 阿里云短信配置（可选，不配置则使用演示模式）
ALIYUN_SMS_ACCESS_KEY_ID=your-access-key-id
ALIYUN_SMS_ACCESS_KEY_SECRET=your-access-key-secret
ALIYUN_SMS_SIGN_NAME=游戏商城
ALIYUN_SMS_TEMPLATE_CODE=SMS_XXXXXXXXX
