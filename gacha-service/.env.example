# ============================================
# Gacha Service 环境配置
# ============================================

# 应用配置
APP_NAME=gacha-service
APP_PORT=8083

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=gacha_system_dev
DB_USERNAME=root
DB_PASSWORD=123456
DB_USE_SSL=false
DB_TIMEZONE=UTC
DB_ENCODING=utf-8

# JPA 配置
JPA_DDL_AUTO=update
JPA_SHOW_SQL=true
JPA_DIALECT=org.hibernate.dialect.MySQLDialect

# 日志配置
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_GACHA=DEBUG
LOG_LEVEL_COMMON=DEBUG
LOG_LEVEL_SPRING_WEB=DEBUG
LOG_LEVEL_HIBERNATE_SQL=DEBUG
