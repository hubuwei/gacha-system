# ============================================
# 环境变量配置文件模板
# 复制此文件为 .env 或 .env.prod 并修改相应配置
# ============================================

# 应用配置
APP_NAME=mall-service
APP_PORT=8081
CONTEXT_PATH=/api

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=gacha_system_dev
DB_USERNAME=root
DB_PASSWORD=123456
DB_ENCODING=utf-8
DB_USE_SSL=false
DB_TIMEZONE=Asia/Shanghai

# JPA配置
JPA_DDL_AUTO=update
JPA_SHOW_SQL=true
JPA_DIALECT=org.hibernate.dialect.MySQL8Dialect
JPA_FORMAT_SQL=true

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0
REDIS_TIMEOUT=5000ms

# RabbitMQ配置
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VIRTUAL_HOST=/

# Elasticsearch配置
ES_URIS=http://localhost:9200
ES_USERNAME=
ES_PASSWORD=
ES_CONNECTION_TIMEOUT=5s
ES_SOCKET_TIMEOUT=30s

# 邮件配置
MAIL_HOST=smtp.qq.com
MAIL_PORT=587
MAIL_USERNAME=your-email@qq.com
MAIL_PASSWORD=your-smtp-password

# 日志配置
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_MALL=DEBUG
LOG_LEVEL_REPOSITORY=DEBUG
LOG_LEVEL_JWT=DEBUG

# JWT配置
JWT_SECRET=ChangeThisSecretKeyInProductionEnvironment2026

# 静态资源配置
# 本地开发：留空（自动检测）
# 生产环境：配置绝对路径，如 /opt/gacha-system/GamePapers
GAME_PAPERS_PATH=
