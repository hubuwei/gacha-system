# ============================================
# Mall Service 环境配置
# ============================================

# 应用配置
APP_NAME=mall-service
APP_PORT=8081
CONTEXT_PATH=/api

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=gacha_system_dev
DB_USERNAME=root
DB_PASSWORD=123456
DB_USE_SSL=false
DB_TIMEZONE=Asia/Shanghai
DB_ENCODING=utf8

# JPA 配置
JPA_DDL_AUTO=update
JPA_SHOW_SQL=true
JPA_DIALECT=org.hibernate.dialect.MySQL8Dialect
JPA_FORMAT_SQL=true

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0
REDIS_TIMEOUT=5000ms

# Elasticsearch 配置
ES_URIS=http://localhost:9200
ES_USERNAME=
ES_PASSWORD=
ES_CONNECTION_TIMEOUT=5s
ES_SOCKET_TIMEOUT=30s

# RabbitMQ 配置
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VIRTUAL_HOST=/

# JWT 配置
JWT_SECRET=ThisIsAVeryLongAndSecureSecretKeyForJWTTokenGenerationWithHS512AlgorithmInGachaSystem2026
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# 短信配置（阿里云）
SMS_ENABLED=true
SMS_ACCESS_KEY_ID=your-access-key-id
SMS_ACCESS_KEY_SECRET=your-access-key-secret
SMS_SIGN_NAME=游戏商城
SMS_TEMPLATE_CODE=SMS_123456789

# OSS 配置（阿里云）
OSS_ENABLED=true
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret
OSS_BUCKET_NAME=game-mall
OSS_BASE_URL=https://game-mall.oss-cn-hangzhou.aliyuncs.com

# 微信支付配置
WECHAT_PAY_APP_ID=your-app-id
WECHAT_PAY_MCH_ID=your-mch-id
WECHAT_PAY_API_V3_KEY=your-api-v3-key
WECHAT_PAY_PRIVATE_KEY_PATH=classpath:cert/apiclient_key.pem
WECHAT_PAY_SERIAL_NO=your-serial-no
WECHAT_PAY_NOTIFY_URL=https://your-domain.com/api/payment/wechat/notify

# 日志配置
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_MALL=DEBUG
LOG_LEVEL_REPOSITORY=DEBUG
LOG_LEVEL_JWT=DEBUG
