{
  "analysis": {
    "analyzer": {
      "ik_max_word": {
        "type": "custom",
        "tokenizer": "ik_max_word"
      },
      "ik_smart": {
        "type": "custom",
        "tokenizer": "ik_smart"
      },
      "pinyin_analyzer": {
        "type": "custom",
        "tokenizer": "pinyin_tokenizer"
      }
    },
    "tokenizer": {
      "ik_max_word": {
        "type": "ik_max_word",
        "use_smart": false
      },
      "ik_smart": {
        "type": "ik_smart",
        "use_smart": true
      },
      "pinyin_tokenizer": {
        "type": "pinyin",
        "keep_first_letter": true,
        "keep_full_pinyin": true,
        "keep_original": true,
        "limit_first_letter_length": 16,
        "lowercase": true,
        "remove_duplicated_term": true
      }
    }
  }
}